POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# config.settings.dev | config.settings.prod
DJANGO_SETTINGS_MODULE=config.settings.dev

# 2FA
TWO_FA_ENCRYPTION_KEY=
TWO_FA_ISSUER_NAME=Managora

# Attendance OTP
# Use console in development to avoid hard dependency on SMTP.
ATTENDANCE_OTP_MODE=email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=creativitycode78@gmail.com
EMAIL_HOST_PASSWORD=iknyxaxheoijgvhf
DEFAULT_FROM_EMAIL=creativitycode78@gmail.com
ATTENDANCE_OTP_SENDER_EMAIL=${EMAIL_HOST_USER}
ATTENDANCE_OTP_APP_PASSWORD=${EMAIL_HOST_PASSWORD}
ATTENDANCE_OTP_SMTP_HOST=smtp.gmail.com
ATTENDANCE_OTP_SMTP_PORT=587

# S3
USE_S3_MEDIA_STORAGE=0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_QUERYSTRING_EXPIRE=300

# Redis / Cache
# In Docker Compose use the redis service name, not localhost.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/1
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=managora
CACHE_REDIS_DB=1
CACHE_SOCKET_CONNECT_TIMEOUT=0.5
CACHE_SOCKET_TIMEOUT=0.5
CACHE_MAX_CONNECTIONS=100
CACHE_HEALTH_CHECK_INTERVAL=30
REDIS_RETRY_ON_TIMEOUT=1
CACHE_MIDDLEWARE_SECONDS=0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500
CELERY_TASK_ALWAYS_EAGER=0
CELERY_TASK_EAGER_PROPAGATES=1